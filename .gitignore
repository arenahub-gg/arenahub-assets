node_modules/
dist/
*.local
.DS_Store
Thumbs.db

# Binary asset payloads are NOT committed — rebuild with: npm run assets:download
# (pack.json metadata stays in git; the 2 packs imported before this policy remain tracked)
assets/*/*
!assets/*/pack.json

# Generated packs (meshy-*) are unique — binaries ARE committed (no re-download source)
!assets/meshy-*/**
